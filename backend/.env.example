# ════════════════════════════════════════════════════════════════════════════════
# AI Interview Prep — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════════════════════

# ─── AI Providers ─────────────────────────────────────────────────────────────
# Groq (free): https://console.groq.com → sign up → API Keys → Create Key
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gemini (free): https://aistudio.google.com → Get API Key → Create API Key
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-long-random-string-minimum-32-chars

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, zero setup) — file is created automatically in backend/
DATABASE_URL=sqlite:///./interview_prep.db

# PostgreSQL example (for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/interview_prep

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Frontend origin — must match exactly (no trailing slash)
FRONTEND_URL=http://localhost:5173
